#!/bin/bash
# Check all internal links in docs/*.md exist on disk.
# Relative links like ./path or ../path are resolved from the doc's location.
set -euo pipefail
REPO="$(cd "$(dirname "$0")/.." && pwd)"
FAILED=0; CHECKED=0

for md in "$REPO"/docs/*.md; do
    [ -f "$md" ] || continue
    doc_dir="$(dirname "$md")"
    # Extract relative links: [text](./...) or [text](../...)
    while IFS= read -r link; do
        [ -z "$link" ] && continue
        CHECKED=$((CHECKED + 1))
        # Resolve relative to doc's directory
        if [[ "$link" == /* ]]; then
            target="$REPO$link"
        else
            target="$(cd "$doc_dir" && realpath -m "$link" 2>/dev/null || echo "$doc_dir/$link")"
        fi
        if [ ! -e "$target" ]; then
            echo "BROKEN: $(basename "$md") -> $link"
            FAILED=$((FAILED + 1))
        fi
    done < <(python3 -c "
import re, sys
text = open('$md').read()
links = re.findall(r'\]\((\./|\.\./)([^)#]+)', text)
for prefix, path in links:
    print(prefix + path)
" 2>/dev/null || true)
done

echo "Checked $CHECKED links across docs/: $FAILED broken"
[ $FAILED -eq 0 ]
