#!/usr/bin/env python3
"""
md-link-check: 检查 markdown 文件中所有链接的有效性。
仅检查外部 HTTP/HTTPS 链接（本地文件链接做存在性检查）。
用法: tools/md-link-check [docs_dir_or_file]
返回: 0 全部通过, 1 有失败
"""
import sys
import re
import urllib.request
import urllib.error
from pathlib import Path

def check_url(url: str, timeout: int = 10) -> tuple[bool, str]:
    try:
        req = urllib.request.Request(
            url,
            headers={'User-Agent': 'md-link-check/1.0'},
            method='HEAD'
        )
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            code = resp.status
            return (code < 400), f"HTTP {code}"
    except urllib.error.HTTPError as e:
        # 有些服务器对 HEAD 返回 405 或 403，改用 GET
        if e.code in (405, 403):
            try:
                req2 = urllib.request.Request(url, headers={'User-Agent': 'md-link-check/1.0'})
                with urllib.request.urlopen(req2, timeout=timeout) as resp2:
                    return True, f"HTTP {resp2.status} (GET fallback)"
            except urllib.error.HTTPError as e3:
                if e3.code < 500:
                    return True, f"HTTP {e3.code} (accessible)"
                return False, f"HTTP {e3.code}"
            except Exception as e2:
                return False, str(e2)
        return False, f"HTTP {e.code}"
    except Exception as e:
        return False, str(e)

def check_local(link: str, base_dir: Path) -> tuple[bool, str]:
    # 去掉 anchor
    path_part = link.split('#')[0]
    if not path_part:
        return True, "anchor only"
    target = (base_dir / path_part).resolve()
    if target.exists():
        return True, "file exists"
    return False, f"file not found: {target}"

def extract_links(md_text: str) -> list[str]:
    """提取 markdown 中所有链接 URL."""
    links = []
    # [text](url)
    links += re.findall(r'\[(?:[^\]]*)\]\(([^)]+)\)', md_text)
    # <url>
    links += re.findall(r'<(https?://[^>]+)>', md_text)
    # 去掉 title 部分 "url 'title'" -> url
    cleaned = []
    for l in links:
        l = l.strip()
        l = re.sub(r'\s+["\'].*$', '', l)
        cleaned.append(l)
    return cleaned

def check_file(md_path: Path) -> list[tuple[str, bool, str]]:
    text = md_path.read_text(encoding='utf-8')
    links = extract_links(text)
    results = []
    base_dir = md_path.parent
    for link in links:
        if link.startswith('http://') or link.startswith('https://'):
            ok, msg = check_url(link)
        else:
            ok, msg = check_local(link, base_dir)
        results.append((link, ok, msg))
    return results

def main():
    target = Path(sys.argv[1]) if len(sys.argv) > 1 else Path('docs')

    if target.is_file():
        md_files = [target]
    elif target.is_dir():
        md_files = sorted(target.rglob('*.md'))
    else:
        print(f"Not found: {target}")
        sys.exit(1)

    if not md_files:
        print(f"No markdown files found in {target}")
        sys.exit(0)

    total_links = 0
    broken = []

    for md in md_files:
        print(f"\n{md}")
        results = check_file(md)
        for link, ok, msg in results:
            total_links += 1
            status = "OK" if ok else "BROKEN"
            print(f"  [{status}] {link[:80]} ({msg})")
            if not ok:
                broken.append((str(md), link, msg))

    print(f"\nTotal links checked: {total_links}")
    print(f"Broken: {len(broken)}")

    if broken:
        sys.exit(1)
    sys.exit(0)

if __name__ == '__main__':
    main()
