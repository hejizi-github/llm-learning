#!/usr/bin/env python3
"""
Score each knowledge node in docs/ on 5 dimensions (0 or 1 each, max 5).
Minimum passing score: 3/5.

Dimensions:
  1. verified_citation   — has at least one [cite_key] reference in text
  2. linked_notebook     — links to a notebook in notebooks/
  3. has_math            — contains ≥1 formula (LaTeX $...$ or fenced math block)
  4. has_intuition       — contains analogies/story (keywords: 类比, 故事, 想象, imagine, analogy, intuition)
  5. has_history         — mentions historical context (year, decade, or prev/next node link)
"""
import re, sys, pathlib

REPO = pathlib.Path(__file__).parent.parent
DOCS = sorted(REPO.glob("docs/*.md"))
MIN_SCORE = 3

if not DOCS:
    print("No docs found.")
    sys.exit(0)

results = []
for doc in DOCS:
    text = doc.read_text()
    name = doc.name

    d1 = bool(re.search(r'\[[@\w]+\]', text) or re.search(r'\[@\w+\]', text))
    d2 = bool(re.search(r'notebooks/', text))
    d3 = bool(re.search(r'\$[^$]+\$|```math', text))
    d4 = bool(re.search(r'类比|故事|想象|imagine|analogy|intuition|比喻|好比|就像|相当于', text, re.I))
    d5 = bool(re.search(r'\d{4}|年代|世纪|上一节|下一节|→|←|前置|后续', text))

    score = sum([d1, d2, d3, d4, d5])
    status = "PASS" if score >= MIN_SCORE else "FAIL"
    results.append((name, score, status, [d1, d2, d3, d4, d5]))
    dims = "".join(["✓" if d else "✗" for d in [d1, d2, d3, d4, d5]])
    print(f"{status} {score}/5 [{dims}] {name}")
    if status == "FAIL":
        labels = ["verified_citation", "linked_notebook", "has_math", "has_intuition", "has_history"]
        missing = [l for l, d in zip(labels, [d1,d2,d3,d4,d5]) if not d]
        print(f"     Missing: {', '.join(missing)}")

passing = sum(1 for _, _, s, _ in results if s == "PASS")
print(f"\ndepth_score: {passing}/{len(results)} nodes passing (≥{MIN_SCORE}/5)")
failing = [n for n, _, s, _ in results if s == "FAIL"]
if failing:
    print("Failing nodes:", failing)
    sys.exit(1)
