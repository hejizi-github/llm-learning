#!/usr/bin/env python3
# observe-session — 把 session 的 stream-json log 解析成人看的时间线
#
# 用法:
#   tools/observe-session                      # 最近一个 session
#   tools/observe-session 20260418-203859      # 指定 session id
#   tools/observe-session --last               # 最近一个
#   tools/observe-session --file PATH          # 指定 log 文件
#   tools/observe-session 20260418-203859 --full  # 展示完整 text（不截断）

import json
import sys
import os
from pathlib import Path
from datetime import datetime

SESSIONS_DIR = Path(".evolve/sessions")

def find_log(session_id=None, explicit_file=None):
    if explicit_file:
        return Path(explicit_file)
    if session_id:
        # 优先主 log，没有就找 fix/review/reflect
        for suffix in ["", "_fix_1", "_fix_2", "_fix_3", "_review", "_reflect"]:
            p = SESSIONS_DIR / f"{session_id}{suffix}.log"
            if p.exists() and p.stat().st_size > 0:
                return p
        # 返回主 log 即使是空
        return SESSIONS_DIR / f"{session_id}.log"
    # 最近一个非空主 log
    logs = sorted(SESSIONS_DIR.glob("*.log"), key=lambda p: p.stat().st_mtime, reverse=True)
    for p in logs:
        if "_fix_" in p.name or "_review" in p.name or "_reflect" in p.name:
            continue
        if p.stat().st_size > 0:
            return p
    return None

def short(text, n=120):
    text = text.replace("\n", " ").strip()
    if len(text) <= n:
        return text
    return text[:n] + "…"

def fmt_time(ts_str):
    # ts_str 形如 "2026-04-18T12:34:56.789Z"
    if not ts_str:
        return "        "
    try:
        dt = datetime.fromisoformat(ts_str.replace("Z", "+00:00"))
        return dt.strftime("%H:%M:%S")
    except Exception:
        return ts_str[:8]

def main():
    args = sys.argv[1:]
    full = "--full" in args
    args = [a for a in args if a != "--full"]

    session_id = None
    explicit_file = None
    if args:
        if args[0] == "--last":
            pass
        elif args[0] == "--file" and len(args) > 1:
            explicit_file = args[1]
        else:
            session_id = args[0]

    log_path = find_log(session_id, explicit_file)
    if not log_path or not log_path.exists():
        print("找不到 session log", file=sys.stderr)
        sys.exit(1)
    if log_path.stat().st_size == 0:
        print(f"log 为空: {log_path}", file=sys.stderr)
        sys.exit(1)

    print(f"# {log_path}")
    print()

    tool_call_names = {}  # id → tool name（连接 call 和 result）
    total_lines = 0
    total_events = {"tool_call": 0, "tool_result": 0, "text": 0, "thinking": 0}

    with log_path.open() as f:
        for raw in f:
            raw = raw.strip()
            if not raw or not raw.startswith("{"):
                continue
            try:
                d = json.loads(raw)
            except json.JSONDecodeError:
                continue
            total_lines += 1

            event_type = d.get("type")
            ts = fmt_time(d.get("timestamp", ""))
            msg = d.get("message", {}) or {}
            content = msg.get("content", []) or []

            if event_type == "system":
                sub = d.get("subtype", "")
                if sub == "init":
                    cwd = d.get("cwd", "?")
                    print(f"[{ts}] ── session 启动 cwd={cwd}")
                continue

            if event_type == "assistant":
                if isinstance(content, list):
                    for c in content:
                        if not isinstance(c, dict):
                            continue
                        ct = c.get("type")
                        if ct == "tool_use":
                            name = c.get("name", "?")
                            inp = c.get("input", {})
                            tool_call_names[c.get("id")] = name
                            # 摘 input 的关键字段
                            input_hint = ""
                            if "command" in inp:
                                input_hint = short(inp["command"], 80)
                            elif "file_path" in inp:
                                input_hint = inp["file_path"]
                            elif "path" in inp:
                                input_hint = inp["path"]
                            elif "pattern" in inp:
                                input_hint = inp["pattern"]
                            elif "url" in inp:
                                input_hint = inp["url"]
                            elif "description" in inp:
                                input_hint = short(inp["description"], 80)
                            else:
                                input_hint = short(json.dumps(inp, ensure_ascii=False), 80)
                            print(f"[{ts}] → {name}({input_hint})")
                            total_events["tool_call"] += 1
                        elif ct == "text":
                            txt = c.get("text", "")
                            if full:
                                print(f"[{ts}] 💬 {txt}")
                            else:
                                print(f"[{ts}] 💬 {short(txt, 200)}")
                            total_events["text"] += 1
                        elif ct == "thinking":
                            txt = c.get("thinking", "")
                            if full:
                                print(f"[{ts}] 🧠 {txt}")
                            else:
                                print(f"[{ts}] 🧠 {short(txt, 200)}")
                            total_events["thinking"] += 1
                continue

            if event_type == "user":
                # tool_result 来自 user 消息
                if isinstance(content, list):
                    for c in content:
                        if not isinstance(c, dict):
                            continue
                        if c.get("type") == "tool_result":
                            tid = c.get("tool_use_id", "")
                            name = tool_call_names.get(tid, "?")
                            result = c.get("content", "")
                            if isinstance(result, list):
                                result = " ".join(
                                    x.get("text", "") if isinstance(x, dict) else str(x)
                                    for x in result
                                )
                            is_err = c.get("is_error", False)
                            marker = "❌" if is_err else "←"
                            if full:
                                print(f"[{ts}] {marker} {name} → {result}")
                            else:
                                print(f"[{ts}] {marker} {name} → {short(str(result), 200)}")
                            total_events["tool_result"] += 1
                continue

            if event_type == "result":
                subt = d.get("subtype", "")
                cost = d.get("total_cost_usd", 0)
                dur_ms = d.get("duration_ms", 0)
                print()
                print(f"[{ts}] ── session 结束 {subt}  ${cost:.4f}  {dur_ms/1000:.1f}s")
                continue

    print()
    print("─" * 60)
    print(f"总事件: {total_lines}  |  "
          f"tool call: {total_events['tool_call']}  "
          f"tool result: {total_events['tool_result']}  "
          f"text: {total_events['text']}  "
          f"thinking: {total_events['thinking']}")

if __name__ == "__main__":
    main()
