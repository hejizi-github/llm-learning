#!/usr/bin/env python3
"""
cite-verify: 核查 references.bib 中所有引用的真实性。
对每条引用：尝试用 DOI（crossref API）或 arxiv ID 验证作者/年份/标题是否可查到。
用法: tools/cite-verify [refs/references.bib]
返回: 0 全部通过, 1 有失败
"""
import sys
import re
import json
import urllib.request
import urllib.parse
import urllib.error
from pathlib import Path

CROSSREF_API = "https://api.crossref.org/works/{doi}"
ARXIV_API = "https://export.arxiv.org/abs/{arxiv_id}"
OPENLIBRARY_API = "https://openlibrary.org/isbn/{isbn}.json"

def fetch_url(url: str, timeout: int = 10) -> tuple[bool, str]:
    try:
        req = urllib.request.Request(url, headers={'User-Agent': 'cite-verify/1.0 (llm-learning; mailto:verify@example.com)'})
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            return True, resp.read().decode('utf-8', errors='replace')
    except urllib.error.HTTPError as e:
        return False, f"HTTP {e.code}"
    except Exception as e:
        return False, str(e)

def verify_doi(doi: str, expected: dict) -> tuple[bool, str]:
    url = CROSSREF_API.format(doi=urllib.parse.quote(doi, safe=''))
    ok, body = fetch_url(url)
    if not ok:
        return False, f"DOI lookup failed: {body}"
    try:
        data = json.loads(body)['message']
        # 检查年份
        if 'year' in expected:
            published = data.get('published', {}).get('date-parts', [[]])[0]
            pub_year = published[0] if published else None
            if pub_year and abs(pub_year - int(expected['year'])) > 1:
                return False, f"Year mismatch: bib says {expected['year']}, crossref says {pub_year}"
        # 检查第一作者姓
        if 'first_author' in expected:
            authors = data.get('author', [])
            if authors:
                family = authors[0].get('family', '').lower()
                if expected['first_author'].lower() not in family:
                    return False, f"Author mismatch: bib says {expected['first_author']}, crossref says {family}"
        return True, "DOI verified"
    except Exception as e:
        return False, f"Parse error: {e}"

def verify_arxiv(arxiv_id: str) -> tuple[bool, str]:
    url = ARXIV_API.format(arxiv_id=arxiv_id)
    ok, body = fetch_url(url)
    if not ok:
        return False, f"arxiv lookup failed: {body}"
    if '<title>' in body and 'Error' not in body[:200]:
        return True, "arxiv ID verified"
    return False, "arxiv page not found"

def verify_isbn(isbn: str) -> tuple[bool, str]:
    clean = isbn.replace('-', '').replace(' ', '')
    url = OPENLIBRARY_API.format(isbn=clean)
    ok, body = fetch_url(url)
    if not ok:
        return False, f"ISBN lookup failed: {body}"
    try:
        data = json.loads(body)
        if 'title' in data or 'works' in data:
            return True, f"ISBN verified via Open Library"
        return False, "ISBN not found in Open Library"
    except Exception as e:
        return False, f"Parse error: {e}"

def parse_bib(bib_path: Path) -> list[dict]:
    """简单解析 .bib，提取每条 entry 的关键字段."""
    text = bib_path.read_text(encoding='utf-8')
    entries = []
    for block in re.split(r'(?=@\w+\{)', text):
        block = block.strip()
        if not block.startswith('@'):
            continue
        entry = {}
        m = re.match(r'@(\w+)\{([^,]+),', block)
        if m:
            entry['type'] = m.group(1).lower()
            entry['key'] = m.group(2).strip()
        for field in ['doi', 'year', 'author', 'title', 'eprint', 'isbn', 'school']:
            m2 = re.search(rf'{field}\s*=\s*[{{"]([^}}"]+)[}}"]+', block, re.IGNORECASE)
            if m2:
                entry[field] = m2.group(1).strip()
        if entry:
            entries.append(entry)
    return entries

def main():
    bib_path = Path(sys.argv[1]) if len(sys.argv) > 1 else Path('refs/references.bib')
    if not bib_path.exists():
        print(f"File not found: {bib_path}")
        sys.exit(1)

    entries = parse_bib(bib_path)
    if not entries:
        print("No entries found in .bib file")
        sys.exit(0)

    print(f"Verifying {len(entries)} citation(s)...\n")
    total = len(entries)
    verified = 0
    failed_list = []

    for entry in entries:
        key = entry.get('key', '?')
        print(f"  [{key}] ... ", end='', flush=True)

        doi = entry.get('doi', '').strip()
        arxiv_id = entry.get('eprint', '').strip()
        isbn = entry.get('isbn', '').strip()

        if doi:
            first_author = ''
            if 'author' in entry:
                first_author = re.split(r'\s+and\s+', entry['author'], flags=re.IGNORECASE)[0]
                # "Last, First" or "First Last" — grab last name
                first_author = first_author.split(',')[0].strip()
            expected = {'year': entry.get('year', ''), 'first_author': first_author}
            ok, msg = verify_doi(doi, expected)
        elif arxiv_id:
            ok, msg = verify_arxiv(arxiv_id)
        elif isbn:
            ok, msg = verify_isbn(isbn)
        elif entry.get('type') == 'phdthesis':
            # 博士论文通常无 DOI；有 school + year 字段即视为可接受
            school = entry.get('school', '').strip()
            year = entry.get('year', '').strip()
            if school and year:
                ok, msg = True, f"phdthesis accepted (school={school}, year={year})"
            else:
                ok, msg = False, "phdthesis missing school or year field"
        else:
            ok, msg = False, "No DOI, arxiv ID, or ISBN found"

        if ok:
            print(f"OK ({msg})")
            verified += 1
        else:
            print(f"FAILED ({msg})")
            failed_list.append((key, msg))

    print()
    ratio = (total - verified) / total if total else 0
    print(f"Verified: {verified}/{total}")
    print(f"unverified_citation_ratio = {ratio:.2f}")

    if failed_list:
        print(f"\nFailed entries:")
        for key, msg in failed_list:
            print(f"  {key}: {msg}")
        sys.exit(1)
    else:
        print("All citations verified.")
        sys.exit(0)

if __name__ == '__main__':
    main()
