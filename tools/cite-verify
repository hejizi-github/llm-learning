#!/usr/bin/env python3
"""Verify DOI and arXiv citations are reachable. Reads a .bib file or plain text list."""
import sys
import re
import urllib.request
import urllib.error
import time

def check_url(url, label=""):
    try:
        req = urllib.request.Request(url, method="HEAD")
        req.add_header("User-Agent", "cite-verify/1.0 (research tool)")
        resp = urllib.request.urlopen(req, timeout=15)
        ok = resp.status < 400
        status = "PASS" if ok else f"FAIL({resp.status})"
        print(f"  {status}: {label or url}")
        return ok
    except urllib.error.HTTPError as e:
        # 405 Method Not Allowed for HEAD → retry with GET
        if e.code == 405:
            try:
                req2 = urllib.request.Request(url, method="GET")
                req2.add_header("User-Agent", "cite-verify/1.0")
                resp2 = urllib.request.urlopen(req2, timeout=15)
                ok = resp2.status < 400
                status = "PASS" if ok else f"FAIL({resp2.status})"
                print(f"  {status}: {label or url}")
                return ok
            except Exception as e2:
                print(f"  FAIL: {label or url} — {e2}")
                return False
        print(f"  FAIL: {label or url} — HTTP {e.code}")
        return False
    except Exception as e:
        print(f"  FAIL: {label or url} — {e}")
        return False

def verify_bib(path):
    with open(path) as f:
        content = f.read()

    results = []

    # Extract DOIs
    for m in re.finditer(r'doi\s*=\s*[{"]([^}"]+)[}"]', content, re.IGNORECASE):
        doi = m.group(1).strip()
        url = f"https://doi.org/{doi}"
        print(f"Checking DOI: {doi}")
        results.append(check_url(url, doi))
        time.sleep(0.5)

    # Extract arXiv IDs
    for m in re.finditer(r'arxiv[:\s]*([0-9]{4}\.[0-9]{4,5})', content, re.IGNORECASE):
        arxiv_id = m.group(1).strip()
        url = f"https://arxiv.org/abs/{arxiv_id}"
        print(f"Checking arXiv: {arxiv_id}")
        results.append(check_url(url, arxiv_id))
        time.sleep(0.5)

    if not results:
        print("No DOIs or arXiv IDs found in file.")
        return True

    passed = sum(results)
    total = len(results)
    print(f"\nResult: {passed}/{total} citations verified")
    return passed == total

if __name__ == "__main__":
    if len(sys.argv) < 2:
        print("Usage: tools/cite-verify <references.bib>")
        sys.exit(1)
    ok = verify_bib(sys.argv[1])
    sys.exit(0 if ok else 1)
