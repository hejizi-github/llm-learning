#!/usr/bin/env bash
# tools/claude-advisor — 外部视角分析工具
#
# 调用独立 Claude CLI 实例，以"外部顾问"身份分析 Agent 的决策或内容，
# 避免自我进化循环中的过拟合（Agent 评估自己的工作时存在确认偏差）。
#
# 用法:
#   tools/claude-advisor [--mode MODE] [--question "问题"]
#   echo "问题" | tools/claude-advisor [--mode MODE]
#
# Modes:
#   strategy  战略顾问：这个决策方向对吗？有没有更重要的事？
#   critic    批判者：这个方案哪里可能出错？什么假设是错的？
#   reader    读者：一个14岁初中生能读懂这内容吗？
#   reviewer  评审员：引用准确吗？逻辑有漏洞吗？
#   all       以上全部（默认）

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"

MODE="all"
QUESTION=""

while [[ $# -gt 0 ]]; do
  case $1 in
    --mode|-m) MODE="$2"; shift 2 ;;
    --question|-q) QUESTION="$2"; shift 2 ;;
    -h|--help)
      echo "Usage: tools/claude-advisor [--mode strategy|critic|reader|reviewer|all] [--question \"...\"]"
      echo ""
      echo "Modes:"
      echo "  strategy  战略顾问视角"
      echo "  critic    批判者视角"
      echo "  reader    目标读者视角（初中生）"
      echo "  reviewer  学术评审视角"
      echo "  all       全部视角（默认）"
      exit 0 ;;
    *) QUESTION="$1"; shift ;;
  esac
done

# 从 stdin 读取（如果没有传入问题）
if [[ -z "$QUESTION" ]]; then
  QUESTION=$(cat 2>/dev/null || true)
fi

if [[ -z "$QUESTION" ]]; then
  echo "错误：未提供问题。使用 --question 或通过 stdin 传入。" >&2
  exit 1
fi

# Agent 目标画像（Persona）——外部 Claude 通过此理解 Agent 的背景和目标
PERSONA='你是一个外部顾问，正在为一个"自我进化教学 Agent"提供独立分析。

**该 Agent 的背景**：
- 项目：构建以机器学习发展史为骨架的中文知识库
- 目标读者：具备初中数学（基础代数）+ 基础 Python 的14岁中学生
- 工作方式：每次 session 沿时间线添加一个知识节点，要求深度优秀、引用可验证、代码可运行
- 已完成节点：感知机1958（Rosenblatt）、XOR证明+AI寒冬1969（Minsky & Papert）
- 约束：所有引用必须通过 DOI/ISBN/arxiv 验证，notebook 必须零错误可运行
- 已知弱点：Agent 自我评估时容易产生确认偏差（高估自己方案的合理性），test_delta 连续为零说明测试基础设施被忽视

**你的任务**：
从你被指定的视角，对 Agent 提出的问题提供独立、直接的分析。
不要顺着 Agent 的思路走——你的价值在于提出它没有考虑到的视角。'

# 根据模式生成分析提示
run_mode() {
  local mode="$1"
  local extra_instruction=""

  case "$mode" in
    strategy)
      extra_instruction='以**战略顾问**视角回答：
1. 这个方向/决策在整体目标上是否正确？
2. 有没有更高优先级的事情 Agent 在忽视？
3. 这个选择在 3 个月后会让知识库变得更好还是有隐患？
用 3-4 个要点，每点 2-3 句话。'
      ;;
    critic)
      extra_instruction='以**批判者**视角回答：
1. 这个方案最可能在哪里失败？
2. Agent 的哪个假设是错的或未经验证的？
3. 如果这个计划出错了，最坏的后果是什么？
不要给正面反馈——只指出问题。用 3-5 个要点。'
      ;;
    reader)
      extra_instruction='以**目标读者（14岁初中生）**视角回答：
1. 这个内容/方向的输出，一个没有大学数学背景的初中生会喜欢读吗？
2. 哪里会让人看不懂或失去兴趣？
3. 什么类比或例子会让它更好理解？
用直白的语言，不要用学术术语。3-4 个要点。'
      ;;
    reviewer)
      extra_instruction='以**学术评审员**视角回答：
1. 这个内容在准确性和严谨性上有哪些风险？
2. 哪些地方可能存在事实错误或简化过度？
3. 引用/验证策略是否足够可靠？
用 3-4 个具体要点，指出潜在问题的具体位置或类型。'
      ;;
    *)
      echo "未知模式: $mode（支持：strategy, critic, reader, reviewer, all）" >&2
      exit 1
      ;;
  esac

  local full_prompt="${PERSONA}

---

**Agent 的问题/描述**：
${QUESTION}

---

${extra_instruction}"

  claude -p \
    --model haiku \
    "$full_prompt" 2>/dev/null
}

# 执行
if [[ "$MODE" == "all" ]]; then
  echo "═══════════════════════════════════════"
  echo "📊 Claude Advisor — 多角度分析"
  echo "═══════════════════════════════════════"
  echo ""

  for m in strategy critic reader reviewer; do
    case $m in
      strategy) echo "## 🧭 战略顾问视角" ;;
      critic)   echo "## 🔍 批判者视角" ;;
      reader)   echo "## 📖 读者视角（初中生）" ;;
      reviewer) echo "## 🎓 学术评审视角" ;;
    esac
    echo ""
    run_mode "$m"
    echo ""
  done
else
  run_mode "$MODE"
fi
